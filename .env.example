# Environment Variable Configuration Template
# Copy this file to .env and customize paths for your specific setup
# These variables override the default platform-specific paths
#
# Platform-specific templates:
# - .env.idun: Template for IDUN HPC cluster (copy to .env on cluster)

# Base path where your code/repositories are located
# PROJECT_CODE_BASE=/Users/ipeglin/Git

# Base path where datasets and raw data are stored
# PROJECT_DATA_BASE=/Users/ipeglin/Documents/Data

# Base paths for different types of outputs
# PROJECT_OUTPUT_BASE=/Users/ipeglin/Documents/Analysis          # General output (backward compatibility)
# PROJECT_PREPROCESSING_BASE=/Users/ipeglin/Documents/Preprocessing  # Data preprocessing outputs
# PROJECT_ANALYSIS_BASE=/Users/ipeglin/Documents/Analysis            # Analysis results
# PROJECT_FIGURES_BASE=/Users/ipeglin/Documents/Figures              # Plots and visualizations
# PROJECT_MODELS_BASE=/Users/ipeglin/Documents/Models                # Trained models and checkpoints
# PROJECT_REPORTS_BASE=/Users/ipeglin/Documents/Reports              # Reports and documentation

# Base path for temporary files during processing
# PROJECT_TEMP_BASE=/tmp

# Platform-specific examples:

# macOS (M1 MacBook)
# PROJECT_CODE_BASE=/Users/ipeglin/Git
# PROJECT_DATA_BASE=/Users/ipeglin/Documents/Data
# PROJECT_PREPROCESSING_BASE=/Users/ipeglin/Documents/Preprocessing
# PROJECT_ANALYSIS_BASE=/Users/ipeglin/Documents/Analysis
# PROJECT_FIGURES_BASE=/Users/ipeglin/Documents/Figures
# PROJECT_MODELS_BASE=/Users/ipeglin/Documents/Models
# PROJECT_REPORTS_BASE=/Users/ipeglin/Documents/Reports
# PROJECT_TEMP_BASE=/tmp

# Windows 11 Desktop
# PROJECT_CODE_BASE=C:/Users/ipeglin/Git
# PROJECT_DATA_BASE=C:/Users/ipeglin/Documents/Data
# PROJECT_PREPROCESSING_BASE=C:/Users/ipeglin/Documents/Preprocessing
# PROJECT_ANALYSIS_BASE=C:/Users/ipeglin/Documents/Analysis
# PROJECT_FIGURES_BASE=C:/Users/ipeglin/Documents/Figures
# PROJECT_MODELS_BASE=C:/Users/ipeglin/Documents/Models
# PROJECT_REPORTS_BASE=C:/Users/ipeglin/Documents/Reports
# PROJECT_TEMP_BASE=C:/temp

# IDUN HPC Cluster
# PROJECT_CODE_BASE=/cluster/home/ianpe
# PROJECT_DATA_BASE=/cluster/work/ianpe
# PROJECT_PREPROCESSING_BASE=/cluster/work/ianpe/preprocessing
# PROJECT_ANALYSIS_BASE=/cluster/work/ianpe/analysis
# PROJECT_FIGURES_BASE=/cluster/work/ianpe/figures
# PROJECT_MODELS_BASE=/cluster/work/ianpe/models
# PROJECT_REPORTS_BASE=/cluster/work/ianpe/reports
# PROJECT_TEMP_BASE=/cluster/work/ianpe/tmp

# Additional Notes:
# - Use absolute paths
# - Ensure the paths exist or can be created
# - For Windows, use forward slashes (/) or double backslashes (\\)
# - Environment variables take precedence over platform detection